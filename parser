    examples = [
        "T",
        "F",
        "P(x)",
        "~P(x)",
        "P(x) & Q(y)",
        "P(x) | Q(y)",
        "P(x) -> Q(x)",
        "~P(x) | Q(x)",
        "(forall x. P(x)) -> Q(a)",
        "(exists x. P(x)) & Q(b)",
        "forall x. (exists y. R(x, y))",
        "(P(x) & Q(x)) -> R(x)",
        "forall x. (P(x) -> (Q(x) | R(x)))",
    ]
    print("=== Parser Self-Test ===\n")
    for src in examples:
        ast = parse(src)
        print(f"  {src:<50}  =>  {ast!r}")
