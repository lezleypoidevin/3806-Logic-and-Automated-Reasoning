# Self-test
# ---------------------------------------------------------------------------

if __name__ == '__main__':
    import sys
    import os

    # If a CSV path is given as an argument use it, otherwise fall back to
    # test_cases.csv sitting next to this script.
    if len(sys.argv) > 1:
        csv_path = sys.argv[1]
    else:
        csv_path = os.path.join(os.path.dirname(os.path.abspath(__file__)), 'test_cases.csv')

    print("\n=== Baseline Solver (Algorithm 2) ===")
    if os.path.exists(csv_path):
        solve_csv(csv_path)
    else:
        print(f"[WARNING] CSV not found at '{csv_path}'.")
        print("Falling back to built-in quick-check...\n")
        for f in ["P -> P", "T", "~F", "P | ~P", "(P & Q) -> P",
                  "(P -> Q) -> (~Q -> ~P)", "((P -> F) -> F) -> P",
                  "(forall x. P(x)) -> P(a)", "P(a) -> (exists x. P(x))"]:
            solve_text(f)
